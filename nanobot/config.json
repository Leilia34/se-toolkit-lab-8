{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 40
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  },
  "providers": {
    "custom": {
      "apiKey": "${LLM_API_KEY}",
      "apiBase": "${LLM_API_BASE_URL}"
    }
  },
  "gateway": {
    "host": "${NANOBOT_GATEWAY_CONTAINER_ADDRESS}",
    "port": "${NANOBOT_GATEWAY_CONTAINER_PORT}"
  },
  "tools": {
    "exec": {
      "enable": true,
      "timeout": 60
    },
    "restrictToWorkspace": false,
    "mcpServers": {
      "lms": {
        "type": "stdio",
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "${NANOBOT_LMS_BACKEND_URL}",
          "NANOBOT_LMS_API_KEY": "${NANOBOT_LMS_API_KEY}"
        }
      }
    }
  }
}
